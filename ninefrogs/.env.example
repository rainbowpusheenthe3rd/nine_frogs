# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: ollama | openai | anthropic
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama

# To use OpenAI:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...

# To use Anthropic:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-5
# LLM_API_KEY=sk-ant-...

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Runs on CPU by default to avoid VRAM contention with Ollama.
# Change to "cuda" if you want GPU embeddings (uses ~500MB VRAM).
EMBED_MODEL=BAAI/bge-base-en-v1.5
EMBED_DEVICE=cpu

# ── Database ───────────────────────────────────────────────────────────────────
# Requires: PostgreSQL running + pgvector extension installed
# Install extension: psql -c "CREATE EXTENSION IF NOT EXISTS vector;"
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ninefrogs

# ── AnkiConnect ────────────────────────────────────────────────────────────────
# Requires: Anki running + AnkiConnect add-on (code 2055492159)
ANKI_URL=http://localhost:8765
ANKI_DEFAULT_DECK=Nine Frogs

# ── Wikipedia ──────────────────────────────────────────────────────────────────
# First run downloads ~500MB to WIKI_CACHE_DIR and builds BM25 index (~2 min).
# Set WIKI_ENABLED=false to skip (web crawl only).
WIKI_ENABLED=true
WIKI_CACHE_DIR=.cache

# ── Web Server ─────────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
